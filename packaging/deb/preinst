#!/bin/sh
set -e

# FilterREX Connector Host — Pre-install
# Creates the service user and config directory.

case "$1" in
  install|upgrade)
    # Create system user if it does not exist
    if ! getent group filterrex >/dev/null 2>&1; then
      groupadd --system filterrex
    fi
    if ! getent passwd filterrex >/dev/null 2>&1; then
      useradd --system --gid filterrex --no-create-home \
        --home-dir /nonexistent --shell /usr/sbin/nologin \
        --comment "FilterREX Connector Host" filterrex
    fi

    # Ensure config directory exists with correct ownership
    mkdir -p /etc/filterrex
    chown root:filterrex /etc/filterrex
    chmod 0750 /etc/filterrex
    ;;
esac

#DEBHELPER#

exit 0
