#!/bin/sh
set -e

# FilterREX Connector Host — Post-remove
# Reloads systemd after unit file removal.
# Config and user are only cleaned on purge.

case "$1" in
  remove)
    # Reload systemd — the package manager removes the unit file
    if [ -d /run/systemd/system ]; then
      systemctl daemon-reload >/dev/null 2>&1 || true
    fi
    ;;
  purge)
    if [ -d /run/systemd/system ]; then
      systemctl daemon-reload >/dev/null 2>&1 || true
    fi
    # Remove config directory on purge
    rm -rf /etc/filterrex
    # Remove service user on purge
    if getent passwd filterrex >/dev/null 2>&1; then
      userdel filterrex 2>/dev/null || true
    fi
    if getent group filterrex >/dev/null 2>&1; then
      groupdel filterrex 2>/dev/null || true
    fi
    ;;
  upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
    ;;
esac

#DEBHELPER#

exit 0
